+def _same_anchor_geometry(
+    first: Any,
+    second: Any,
+    tolerance: float = 1e-6,
+) -> bool:
+    """Compare only serialized y/x geometry, never model confidence or source."""
+
+    if not isinstance(first, list) or not isinstance(second, list):
+        return False
+    if len(first) != len(second):
+        return False
+    for left, right in zip(first, second):
+        if not isinstance(left, dict) or not isinstance(right, dict):
+            return False
+        if not all(_is_finite_number(item.get(axis)) for item in (left, right) for axis in ("y", "x")):
+            return False
+        if abs(float(left["y"]) - float(right["y"])) > tolerance:
+            return False
+        if abs(float(left["x"]) - float(right["x"])) > tolerance:
+            return False
+    return True
+
