diff --git a/low_light_dataset/review_web/styles.css b/low_light_dataset/review_web/styles.css
new file mode 100644
index 0000000..038e3b7
--- /dev/null
+++ b/low_light_dataset/review_web/styles.css
@@ -0,0 +1,251 @@
+:root {
+  color-scheme: dark;
+  font-family: Inter, "Microsoft YaHei", "PingFang SC", system-ui, sans-serif;
+  background: #08111f;
+  color: #e5edf7;
+  --panel: #111c2e;
+  --panel-border: #2a3b55;
+  --muted: #9eafc6;
+  --focus: #69c6ff;
+  --accent: #27b3a2;
+}
+
+* { box-sizing: border-box; }
+
+html, body { min-height: 100%; }
+
+body {
+  margin: 0;
+  background: radial-gradient(circle at 48% 0%, #172942 0, #08111f 48rem);
+  overflow-x: hidden;
+}
+
+button, input, select, textarea { font: inherit; }
+
+button, select, input, textarea {
+  color: #eef5ff;
+  background: #0b1627;
+  border: 1px solid #3a4d68;
+  border-radius: 0.4rem;
+}
+
+button {
+  min-height: 2.4rem;
+  padding: 0.52rem 0.8rem;
+  cursor: pointer;
+  font-weight: 700;
+}
+
+button:hover:not(:disabled) { border-color: #7bc6f2; background: #162841; }
+button:disabled { cursor: not-allowed; opacity: 0.45; }
+
+:focus-visible {
+  outline: 3px solid var(--focus);
+  outline-offset: 2px;
+}
+
+.app-header {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 1rem;
+  padding: 0.75rem clamp(0.8rem, 2vw, 1.5rem);
+}
+
+h1, h2, h3, p { margin-top: 0; }
+h1 { margin-bottom: 0; font-size: clamp(1.35rem, 2.4vw, 2rem); }
+h2 { margin-bottom: 0.7rem; font-size: 1.08rem; }
+h3 { font-size: 0.95rem; }
+
+.eyebrow {
+  margin-bottom: 0.2rem;
+  color: #72d6ca;
+  font-size: 0.72rem;
+  font-weight: 800;
+  letter-spacing: 0.16em;
+}
+
+.summary { color: #cbd8e8; font-variant-numeric: tabular-nums; }
+
+.safety-banner {
+  position: relative;
+  z-index: 1;
+  padding: 0.65rem 1rem;
+  color: #fff7ce;
+  background: #5a4400;
+  border-block: 1px solid #d4a900;
+  text-align: center;
+  font-weight: 800;
+}
+
+.workspace {
+  display: grid;
+  grid-template-columns: minmax(12rem, 0.7fr) minmax(32rem, 2.25fr) minmax(18rem, 1fr);
+  gap: 0.75rem;
+  width: 100%;
+  padding: 0.75rem;
+  align-items: start;
+}
+
+.panel {
+  min-width: 0;
+  padding: 0.85rem;
+  background: color-mix(in srgb, var(--panel) 94%, transparent);
+  border: 1px solid var(--panel-border);
+  border-radius: 0.65rem;
+  box-shadow: 0 0.8rem 2.5rem rgb(0 0 0 / 18%);
+}
+
+.queue-panel, .review-panel { display: grid; gap: 0.42rem; }
+label, legend { color: #c6d5e8; font-size: 0.84rem; font-weight: 700; }
+select, input[type="text"], textarea { width: 100%; padding: 0.5rem 0.55rem; }
+textarea { resize: vertical; }
+#record-select { min-height: 18rem; }
+
+.viewer-heading, .status-row {
+  display: flex;
+  justify-content: space-between;
+  align-items: start;
+  gap: 1rem;
+}
+
+.viewer-heading p { margin-bottom: 0.25rem; color: var(--muted); }
+.toggle { display: flex; align-items: center; gap: 0.45rem; white-space: nowrap; }
+
+.canvas-shell {
+  width: min(100%, calc((100vh - 21rem) * 4 / 3));
+  min-width: min(100%, 30rem);
+  margin-inline: auto;
+  aspect-ratio: 4 / 3;
+  background: #030712;
+  border: 1px solid #52657e;
+  border-radius: 0.35rem;
+  overflow: hidden;
+}
+
+#hose-canvas {
+  display: block;
+  width: 100%;
+  height: 100%;
+  touch-action: none;
+  cursor: crosshair;
+}
+
+.legend {
+  margin: 0.45rem 0;
+  color: #cbd8e8;
+  text-align: center;
+  font-size: 0.82rem;
+}
+
+.amber-line, .red-line {
+  display: inline-block;
+  width: 1.5rem;
+  margin: 0 0.35rem 0.2rem 0.7rem;
+  border-top: 3px solid #f59e0b;
+}
+.red-line { border-color: #ef4444; }
+
+.editor-toolbar {
+  display: flex;
+  justify-content: center;
+  flex-wrap: wrap;
+  gap: 0.45rem;
+}
+.danger-quiet { color: #ffb4b4; }
+
+.neighbor-strip {
+  display: grid;
+  grid-template-columns: repeat(3, minmax(0, 1fr));
+  gap: 0.55rem;
+  margin-top: 0.65rem;
+}
+
+.neighbor-card {
+  display: grid;
+  gap: 0.3rem;
+  min-width: 0;
+  padding: 0.45rem;
+  background: #0a1424;
+  border: 1px solid #2d405a;
+  border-radius: 0.45rem;
+  text-align: center;
+  color: var(--muted);
+  font-size: 0.78rem;
+}
+
+.neighbor-card img {
+  display: block;
+  width: 100%;
+  aspect-ratio: 4 / 3;
+  object-fit: cover;
+  background: #020617;
+}
+.neighbor-card img[hidden] { display: none; }
+.current-card { border-color: #287d77; }
+
+.revision {
+  padding: 0.25rem 0.5rem;
+  color: #b8eee8;
+  background: #153b3a;
+  border-radius: 99rem;
+  white-space: nowrap;
+  font-size: 0.78rem;
+}
+
+fieldset {
+  margin: 0.25rem 0;
+  padding: 0.65rem;
+  border: 1px solid #3a4d68;
+  border-radius: 0.45rem;
+}
+
+.check-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 0.45rem; }
+.check-grid label { display: flex; align-items: start; gap: 0.35rem; font-weight: 500; }
+
+.suggestion-box {
+  margin-top: 0.3rem;
+  padding: 0.65rem;
+  color: #ffe6a7;
+  background: #33270c;
+  border-left: 4px solid #f59e0b;
+  border-radius: 0.3rem;
+}
+.suggestion-box h3, .suggestion-box p { margin-bottom: 0.3rem; }
+.suggestion-box p { font-size: 0.82rem; }
+
+.classification-preview {
+  margin: 0.25rem 0;
+  padding: 0.55rem;
+  color: #dbeafe;
+  background: #172b47;
+  border-radius: 0.4rem;
+  font-weight: 700;
+  text-align: center;
+}
+
+.classification-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 0.45rem; }
+.classification-grid .positive { color: #d7fff8; border-color: #2dbdac; }
+.save-button { width: 100%; margin-top: 0.25rem; background: #176c63; border-color: #3bcdbb; }
+.save-result { min-height: 2.5rem; margin: 0; padding: 0.5rem; color: #c9f7e8; font-size: 0.84rem; }
+.save-result.error { color: #ffc2c2; background: #4a1c24; border-radius: 0.35rem; }
+
+@media (max-width: 1060px) {
+  .workspace { grid-template-columns: minmax(11rem, 0.7fr) minmax(30rem, 2fr); }
+  .review-panel { grid-column: 1 / -1; grid-template-columns: repeat(2, minmax(0, 1fr)); }
+  .review-panel > h2, .review-panel > .status-row, .review-panel > fieldset,
+  .review-panel > .suggestion-box, .review-panel > .classification-preview,
+  .review-panel > .classification-grid, .review-panel > .save-button,
+  .review-panel > .save-result { grid-column: 1 / -1; }
+}
+
+@media (max-width: 760px) {
+  .app-header, .viewer-heading, .status-row { align-items: stretch; flex-direction: column; }
+  .workspace { display: grid; grid-template-columns: minmax(0, 1fr); padding: 0.5rem; }
+  .queue-panel, .viewer-panel, .review-panel { grid-column: 1; }
+  .review-panel { grid-template-columns: minmax(0, 1fr); }
+  #record-select { min-height: 10rem; }
+  .canvas-shell { width: 100%; min-width: 0; }
+  .neighbor-strip { grid-template-columns: minmax(0, 1fr); }
+  .classification-grid, .check-grid { grid-template-columns: minmax(0, 1fr); }
+}
