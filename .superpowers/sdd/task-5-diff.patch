+  const state = {
+    records: [],
+    queue: [],
+    detail: null,
+    anchors: [],
+    suggestionAnchors: [],
+    selectedIndex: null,
+    dragging: false,
+    dragSnapshot: null,
+    undoStack: [],
+    redoStack: [],
+  };
